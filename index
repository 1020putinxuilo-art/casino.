<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>ULTRA CASINO 3D</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: linear-gradient(135deg, #0a001f, #1a0033);
      color: #fff;
      font-family: 'Arial', sans-serif;
      text-align: center;
      overflow: hidden;
      height: 100vh;
    }
    canvas { display: block; }
    .container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 10;
      padding: 20px;
      box-sizing: border-box;
    }
    .neon {
      text-shadow: 0 0 10px #ff00ff, 0 0 20px #00ffff, 0 0 30px #ff00ff;
      font-size: 2.5em;
      margin: 10px 0;
    }
    #balance {
      font-size: 1.6em;
      color: #00ffcc;
      text-shadow: 0 0 15px #00ffcc;
    }
    button {
      background: linear-gradient(#ff00aa, #cc0088);
      color: #fff;
      border: none;
      padding: 15px 30px;
      font-size: 18px;
      border-radius: 50px;
      margin: 12px;
      cursor: pointer;
      box-shadow: 0 0 25px #ff00ff;
      transition: all 0.3s;
    }
    button:hover {
      transform: scale(1.05);
      box-shadow: 0 0 35px #ff00ff;
    }
    .info {
      margin: 15px 0;
      font-size: 1.1em;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1 class="neon">🎰 ULTRA CASINO</h1>
    <div class="info">
      👤 <span id="username"></span><br>
      💰 Баланс: <span id="balance">0</span>₽
    </div>

    <button onclick="startBlackjack()">🃏 Играть в Блэкджек</button>
    <button onclick="Telegram.WebApp.close()">❌ Закрыть</button>
  </div>

  <script>
    // Инициализация Telegram WebApp
    const tg = window.Telegram.WebApp;
    tg.ready();
    tg.expand();
    tg.MainButton.setText("Вернуться в бот").show();

    // Получаем данные пользователя
    const user = tg.initDataUnsafe.user || {};
    document.getElementById('username').textContent = user.first_name || 'Игрок';

    // === 3D СЦЕНА ===
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setClearColor(0x0a001f, 1);
    document.body.appendChild(renderer.domElement);

    // Создаём карту
    const geometry = new THREE.PlaneGeometry(4, 5.6);
    const material = new THREE.MeshBasicMaterial({
      color: 0xff00aa,
      side: THREE.DoubleSide
    });
    const card = new THREE.Mesh(geometry, material);
    scene.add(card);

    camera.position.z = 7;

    function animate() {
      requestAnimationFrame(animate);
      card.rotation.y += 0.008;
      card.rotation.x = Math.sin(Date.now() / 1000) * 0.1;
      renderer.render(scene, camera);
    }
    animate();

    // Адаптация под изменение размера окна
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    // Функция запуска игры
    function startBlackjack() {
      const balance = document.getElementById('balance').textContent;
      
      // Отправляем данные в бот
      tg.sendData(JSON.stringify({
        action: "play_blackjack",
        balance: parseInt(balance),
        username: user.first_name || "Игрок"
      }));
      
      // Показываем кнопку возврата
      tg.MainButton.show();
    }

    // Получаем данные от бота (баланс и т.д.)
    tg.onEvent('viewportChanged', () => tg.expand());

    // Если бот пришлёт данные через WebApp (на будущее)
    window.addEventListener('message', function(event) {
      if (event.data && event.data.balance !== undefined) {
        document.getElementById('balance').textContent = event.data.balance;
      }
    });

    // Запрос баланса при открытии (бот может отправить сразу)
    tg.sendData(JSON.stringify({ action: "get_balance" }));
  </script>
</body>
</html>
